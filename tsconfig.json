{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "types": ["node"],

    "verbatimModuleSyntax": true,
    "moduleDetection": "force",

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "skipLibCheck": true,

    "noEmit": true
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}